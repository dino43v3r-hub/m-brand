---
export interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const companionClass = ['dino-companion', className].filter(Boolean).join(' ');
---

<img
  class={companionClass}
  src="/images/dino/interior-dino-companion-v1.0.png"
  alt="Dino, the ConnectAloud interior page companion."
  loading="lazy"
  decoding="async"
/>
