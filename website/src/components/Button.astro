---
export interface Props {
  href: string;
  variant?: 'primary' | 'secondary';
  label?: string;
}

const { href, variant = 'primary', label } = Astro.props;
const className = `button ${variant}`;
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base.slice(0, -1) : base;
const isRootRelativePage = href.startsWith('/') && !href.startsWith('//');
const resolvedHref = isRootRelativePage ? `${basePath}${href === '/' ? '/' : href}` : href;
---

<a class={className} href={resolvedHref} aria-label={label}>
  <slot />
</a>
