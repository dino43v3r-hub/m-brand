---
export interface Props {
  id: string;
  title: string;
  variant?: 'default' | 'statement';
}

const { id, title, variant = 'default' } = Astro.props;
const headingId = `${id}-heading`;
---

<section class="section" id={id} aria-labelledby={headingId}>
  {
    variant === 'statement' ? (
      <div class="statement">
        <h2 id={headingId}>{title}</h2>
        <slot />
      </div>
    ) : (
      <>
        <h2 id={headingId}>{title}</h2>
        <slot />
      </>
    )
  }
</section>
