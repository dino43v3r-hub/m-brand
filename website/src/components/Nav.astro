---
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base.slice(0, -1) : base;
const pathname = Astro.url.pathname;
const pathWithoutBase =
  basePath && pathname.startsWith(basePath) ? pathname.slice(basePath.length) || '/' : pathname;
const currentPath = pathWithoutBase.replace(/\/$/, '') || '/';

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/connectaloud', label: 'Articles' },
  { href: '/projects', label: 'Projects' },
  { href: '/resources', label: 'Resources' },
  { href: '/speaking', label: 'Speaking' },
  { href: '/contact', label: 'Contact' },
];

const withBase = (path: string) => {
  return `${basePath}${path === '/' ? '/' : path}`;
};

const isActive = (href: string) => {
  const normalizedHref = href.replace(/\/$/, '') || '/';
  return normalizedHref === '/'
    ? currentPath === normalizedHref
    : currentPath === normalizedHref || currentPath.startsWith(`${normalizedHref}/`);
};
---

<header class="site-header" aria-label="Site header">
  <a class="brand-mark" href={withBase('/')} aria-label="ConnectAloud home">
    <span class="brand-icon" aria-hidden="true">C</span>
    <span class="brand-name">ConnectAloud</span>
  </a>
  <nav class="site-nav" aria-label="Primary navigation">
    {
      navItems.map((item) => (
        <a
          href={withBase(item.href)}
          class:list={[{ active: isActive(item.href) }]}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))
    }
  </nav>
</header>
