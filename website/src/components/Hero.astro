---
import Button from './Button.astro';

export interface Props {
  eyebrow: string;
  title: string;
  lead: string;
  image: ImageMetadata;
  imageAlt: string;
  caption: string;
  primaryAction: {
    href: string;
    label: string;
  };
  secondaryAction?: {
    href: string;
    label: string;
  };
}

const {
  eyebrow,
  title,
  lead,
  image,
  imageAlt,
  caption,
  primaryAction,
  secondaryAction,
} = Astro.props;
---

<section class="hero" aria-labelledby="page-title">
  <div class="hero-copy">
    <p class="eyebrow">{eyebrow}</p>
    <h1 id="page-title">{title}</h1>
    <p class="lead">{lead}</p>
    <div class="hero-actions" aria-label="Page sections">
      <Button href={primaryAction.href}>{primaryAction.label}</Button>
      {secondaryAction && <Button href={secondaryAction.href} variant="secondary">{secondaryAction.label}</Button>}
    </div>
  </div>

  <aside class="hero-card" aria-label="Dino, the ConnectAloud companion">
    <img
      src={image.src}
      width={image.width}
      height={image.height}
      alt={imageAlt}
      loading="eager"
      decoding="async"
    />
    <p class="caption">{caption}</p>
  </aside>
</section>
