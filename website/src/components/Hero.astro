---
import Button from './Button.astro';

export interface Props {
  eyebrow: string;
  title: string;
  lead: string;
  image: ImageMetadata | string;
  imageAlt: string;
  caption: string;
  primaryAction: {
    href: string;
    label: string;
  };
  secondaryAction?: {
    href: string;
    label: string;
  };
}

const {
  eyebrow,
  title,
  lead,
  image,
  imageAlt,
  caption,
  primaryAction,
  secondaryAction,
} = Astro.props;

const withBasePath = (path: string) => {
  const isExternal = /^(?:[a-z][a-z\d+.-]*:)?\/\//i.test(path);

  if (isExternal || path.startsWith('data:') || path.startsWith('#')) {
    return path;
  }

  const base = import.meta.env.BASE_URL;
  const normalizedBase = base.endsWith('/') ? base : `${base}/`;

  if (path.startsWith(normalizedBase)) {
    return path;
  }

  return `${normalizedBase}${path.replace(/^\/+/, '')}`;
};

const imageSrc = typeof image === 'string' ? withBasePath(image) : image.src;
const imageWidth = typeof image === 'string' ? undefined : image.width;
const imageHeight = typeof image === 'string' ? undefined : image.height;
---

<section class="hero" aria-labelledby="page-title">
  <div class="hero-copy">
    <p class="eyebrow">{eyebrow}</p>
    <h1 id="page-title">{title}</h1>
    <p class="lead">{lead}</p>
    <div class="hero-actions" aria-label="Page sections">
      <Button href={primaryAction.href}>{primaryAction.label}</Button>
      {secondaryAction && <Button href={secondaryAction.href} variant="secondary">{secondaryAction.label}</Button>}
    </div>
  </div>

  <aside class="hero-card" aria-label="Dino, the ConnectAloud companion">
    <img
      src={imageSrc}
      width={imageWidth}
      height={imageHeight}
      alt={imageAlt}
      loading="eager"
      decoding="async"
    />
    <p class="caption">{caption}</p>
  </aside>
</section>
