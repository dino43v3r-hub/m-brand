---
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogImage?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  keywords?: string | string[];
}

const {
  title,
  description,
  canonicalPath = Astro.url.pathname,
  ogImage,
  type = 'website',
  publishedTime,
  modifiedTime,
  author,
  keywords,
} = Astro.props;
const siteName = 'ConnectAloud';
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base.slice(0, -1) : base;
const site = Astro.site ?? new URL(Astro.url.origin);

const withBase = (path: string) => {
  if (/^https?:\/\//.test(path)) return path;
  const normalizedPath = path.startsWith('/') ? path : `/${path}`;
  return `${basePath}${normalizedPath}`;
};

const absoluteUrl = (path: string) => new URL(withBase(path), site).toString();
const canonicalUrl = absoluteUrl(canonicalPath);
const ogImageUrl = ogImage ? absoluteUrl(ogImage) : undefined;
const rssUrl = absoluteUrl('/rss.xml');
const keywordContent = Array.isArray(keywords) ? keywords.join(', ') : keywords;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#f8f9fa" />
    {author && <meta name="author" content={author} />}
    {keywordContent && <meta name="keywords" content={keywordContent} />}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title={`${siteName} RSS`} href={rssUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content={type} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    {type === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {type === 'article' && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {type === 'article' && author && <meta property="article:author" content={author} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <Nav />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
