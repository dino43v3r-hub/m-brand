---
import Card from '../components/Card.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import { latestArticle } from '../data/articles';
import BaseLayout from '../layouts/BaseLayout.astro';

const pageDescription =
  'ConnectAloud is a thoughtful publication exploring artificial intelligence, technology, leadership, theology, and lifelong learning with curiosity, humility, and intellectual honesty.';
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base.slice(0, -1) : base;
const withBase = (path: string) => `${basePath}${path}`;
---

<BaseLayout
  title="ConnectAloud"
  description={pageDescription}
  type="website"
  canonicalPath="/"
  ogImage="/images/dino/thinking-dino-v1.0.png"
  author="M"
  keywords="AI, technology, leadership, theology, responsible AI, ConnectAloud"
>
  <div class="home-page">
  <Hero
    title="Every meaningful conversation begins with a thoughtful question."
    brandName="ConnectAloud"
    lead="ConnectAloud explores artificial intelligence, technology, leadership, and theology through curiosity, intellectual honesty, and a commitment to lifelong learning."
    image="/images/dino/thinking-dino-v1.0.png"
    imageAlt="Dino, the ConnectAloud companion, sitting thoughtfully at a laptop."
    primaryAction={{ href: '/connectaloud', label: 'Start Reading' }}
    secondaryAction={{ href: '/about', label: 'About ConnectAloud' }}
  />

  <Section id="connectaloud" title="Latest Conversation">
    <div class="framework-panel publication-feature">
      <p class="conversation-badge">{latestArticle.collection}</p>
      <div class="article-card-meta">
        <span>{latestArticle.displayDate}</span>
        <span>{latestArticle.readingTime}</span>
      </div>
      <h3>{latestArticle.title}</h3>
      <p>
        A Saturday Morning Coffee with Dino conversation that began with AI ethics and opened into memory, identity, patterns, and what it means to be human.
      </p>
      <div class="publication-links">
        <a href={withBase(latestArticle.href)}>Read the conversation</a>
        <a href={withBase('/coffee-with-dino/')}>Explore Coffee with Dino</a>
      </div>
    </div>
  </Section>

  <Section id="find-here" title="Why ConnectAloud Exists">
    <p class="section-intro">
      ConnectAloud exists to create space for better questions, careful reasoning, and conversations that continue beyond a single answer. It brings together artificial intelligence, technology, leadership, theology, ethics, and lifelong learning without pretending that complex ideas are simple.
    </p>
    <div class="focus-grid">
      <Card title="Thoughtful AI">
        <p>Clear conversations about artificial intelligence, trust, transparency, governance, and technology that strengthens human reasoning.</p>
      </Card>
      <Card title="Leadership and Learning">
        <p>Reflections on clear thinking, intellectual honesty, decision making, and the ongoing work of learning well.</p>
      </Card>
      <Card title="Theology and Ethics">
        <p>Careful attention to truth, humility, human responsibility, and the deeper questions technology raises.</p>
      </Card>
    </div>
  </Section>

  <Section id="principles" title="What Guides Our Conversations">
    <p class="principles-intro">
      To thoughtfully explore how artificial intelligence can become more trustworthy, transparent, and useful while strengthening human reasoning, encouraging intellectual honesty, and serving people through responsible innovation.
    </p>
    <div class="principles-grid">
      <Card title="Curiosity before certainty">
        <p>Good questions create room for better understanding, especially when the answers are still developing.</p>
      </Card>
      <Card title="Trust through transparency">
        <p>Trust is earned through clear reasoning, honest limits, and a willingness to keep learning.</p>
      </Card>
      <Card title="Technology in service of people">
        <p>Responsible innovation should strengthen people rather than replace the human work of judgment, care, and wisdom.</p>
      </Card>
    </div>
  </Section>
  </div>
</BaseLayout>
