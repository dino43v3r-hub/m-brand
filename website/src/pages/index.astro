---
import Card from '../components/Card.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import dinoImage from '../../../assets/canonical/dino/Dino_Master_v1.0.png';

const pageDescription =
  'The M Brand explores artificial intelligence, technology, leadership, theology, and lifelong learning with curiosity, humility, and intellectual honesty.';
---

<BaseLayout title="M Brand" description={pageDescription}>
  <Hero
    eyebrow="Curiosity. Clarity. Responsible innovation."
    title="Thoughtful exploration at the intersection of AI, technology, leadership, and theology."
    lead="The M Brand exists to encourage better questions, clearer reasoning, and trustworthy conversations about how technology can serve people with humility."
    image={dinoImage}
    imageAlt="Dino, the M Brand companion, sitting thoughtfully at a laptop."
    caption="Dino supports the conversation as a visual companion for curiosity, humility, and lifelong learning."
    primaryAction={{ href: '#mission', label: 'Read the mission' }}
    secondaryAction={{ href: '#focus', label: 'Explore the focus' }}
  />

  <Section id="mission" title="Mission" variant="statement">
    <p>
      To thoughtfully explore how artificial intelligence can become more trustworthy, transparent, and useful while strengthening human reasoning, encouraging intellectual honesty, and serving people through responsible innovation.
    </p>
  </Section>

  <Section id="focus" title="Areas of Focus">
    <div class="focus-grid">
      <Card title="Responsible AI">
        <p>Exploring transparency, governance, trust, and technology that strengthens rather than replaces human reasoning.</p>
      </Card>
      <Card title="Leadership and Learning">
        <p>Encouraging clear thinking, intellectual honesty, and lifelong learning across technical and organizational work.</p>
      </Card>
      <Card title="Theology and Ethics">
        <p>Inviting thoughtful conversations about truth, humility, philosophy, and the human questions surrounding technology.</p>
      </Card>
    </div>
  </Section>

  <Section id="voice" title="How the Brand Speaks">
    <div class="intro-grid">
      <Card title="Curious and honest">
        <p>The voice favors questions, reflection, and transparency over certainty for its own sake.</p>
      </Card>
      <Card title="Warm and professional">
        <p>The design and writing stay calm, clear, approachable, and respectful of the reader's time.</p>
      </Card>
    </div>
  </Section>
</BaseLayout>
