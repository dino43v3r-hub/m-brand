---
import DinoCompanion from '../components/DinoCompanion.astro';
import Section from '../components/Section.astro';
import { articles } from '../data/articles';
import BaseLayout from '../layouts/BaseLayout.astro';

const pageDescription =
  'The ConnectAloud archive gathers thoughtful conversations about AI, technology, leadership, faith, and what it means to be human.';
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base.slice(0, -1) : base;
const withBase = (path: string) => `${basePath}${path}`;

const coffeeArticles = articles.filter(
  (article) => article.collection === 'Saturday Morning Coffee with Dino',
);
---

<BaseLayout
  title="ConnectAloud Articles | ConnectAloud"
  description={pageDescription}
  type="website"
  canonicalPath="/connectaloud/"
  ogImage="/images/dino/thinking-dino-v1.0.png"
  author="M"
  keywords="ConnectAloud articles, AI, technology, leadership, theology, lifelong learning"
>
  <section class="page-hero with-companion" aria-labelledby="page-title">
    <p class="eyebrow">Archive</p>
    <h1 id="page-title">ConnectAloud Articles</h1>
    <p class="lead">
      A growing archive of thoughtful conversations for readers who want to approach complex questions with curiosity, care, and room to keep thinking.
    </p>
    <DinoCompanion />
  </section>

  <Section id="coffee-with-dino" title="Saturday Morning Coffee with Dino">
    <p class="section-intro">
      Occasional conversations about AI, leadership, technology, faith, and what it means to be human.
    </p>
    <div class="article-grid">
      {
        coffeeArticles.map((article) => (
          <a class="article-card" href={withBase(article.href)}>
            <div class="article-card-meta">
              <span>{article.displayDate}</span>
              <span>{article.readingTime}</span>
            </div>
            <h3>{article.title}</h3>
            <p>{article.description}</p>
            <ul class="tag-list" aria-label="Article tags">
              {article.tags.map((tag) => (
                <li>{tag}</li>
              ))}
            </ul>
          </a>
        ))
      }
    </div>
  </Section>
</BaseLayout>
