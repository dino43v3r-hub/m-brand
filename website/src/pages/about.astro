---
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import DinoCompanion from '../components/DinoCompanion.astro';
import Section from '../components/Section.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const pageDescription =
  'Learn why ConnectAloud exists as a thoughtful, conversational publication exploring AI, technology, leadership, theology, and lifelong learning.';
const base = import.meta.env.BASE_URL;
const normalizedBase = base.endsWith('/') ? base : `${base}/`;
const heroImage = `${normalizedBase}images/dino/thinking-dino-v1.0.png`;
---

<BaseLayout title="About | ConnectAloud" description={pageDescription}>
  <div class="about-page">
    <section class="about-hero" aria-labelledby="page-title">
      <div class="about-hero-copy">
        <p class="eyebrow">About</p>
        <h1 id="page-title">About ConnectAloud</h1>
        <p class="about-hero-support">Where thoughtful conversations begin.</p>
        <div class="about-hero-body">
          <p>Technology is changing how we learn, work, communicate, and lead.</p>
          <p>ConnectAloud exists because those changes deserve careful thinking—not just quick opinions.</p>
        </div>
      </div>
      <div class="about-hero-art">
        <img
          src={heroImage}
          alt="Dino, the ConnectAloud companion, sitting thoughtfully at a laptop."
          loading="eager"
          decoding="async"
        />
      </div>
    </section>

    <Section id="why-connectaloud-exists" title="Why ConnectAloud Exists">
      <div class="about-editorial-copy">
        <p>Technology is changing how people learn, work, communicate, and make decisions.</p>
        <p>ConnectAloud was created because those changes deserve thoughtful conversation—not just quick reactions.</p>
        <p>This is not a place to tell people what to think.</p>
        <p class="editorial-emphasis">It is a place to think together.</p>
      </div>
    </Section>

    <Section id="what-youll-find-here" title="What You'll Find Here">
      <div class="about-topic-grid">
        <Card title="Artificial Intelligence">
          <p>Responsible AI, trust, transparency, governance, and the ways technology can strengthen human reasoning.</p>
        </Card>
        <Card title="Technology and Leadership">
          <p>Information technology, leadership, decision making, organizational responsibility, and the practical work of leading with clarity.</p>
        </Card>
        <Card title="Theology and Ethics">
          <p>Questions about truth, humility, human responsibility, wisdom, and what technology asks us to consider about people.</p>
        </Card>
        <Card title="Coffee with Dino">
          <p>Thoughtful reflections, ongoing questions, and conversations that continue beyond a single answer.</p>
        </Card>
      </div>
    </Section>

    <Section id="what-guides-our-conversations" title="What Guides Our Conversations">
      <div class="about-section-intro">
        <p>ConnectAloud values curiosity over certainty, transparency over performance, and careful reasoning over quick answers.</p>
        <p>Trust grows through honest limits, thoughtful questions, and a willingness to keep learning.</p>
      </div>
      <div class="principles-grid">
        <Card title="Curiosity Before Certainty">
          <p>Better questions create room for deeper understanding, especially when the answers are still developing.</p>
        </Card>
        <Card title="Trust Through Transparency">
          <p>Clear reasoning, honest limits, and openness about uncertainty are essential to meaningful conversation.</p>
        </Card>
        <Card title="Learning Never Ends">
          <p>Understanding grows through reflection, experience, dialogue, and the willingness to revise what we think we know.</p>
        </Card>
      </div>
    </Section>

    <Section id="why-dino" title="Why Dino?">
      <div class="why-dino-layout">
        <div class="why-dino-copy">
          <p>People occasionally ask:</p>
          <p class="dino-question">Why a dinosaur?</p>
          <p>Because curiosity does not belong only to experts.</p>
          <p>Sometimes the most honest place to begin is with:</p>
          <p class="dino-quote">“I don’t know yet.”</p>
          <p>Dino is not here because he has all the answers.</p>
          <p>He is here to remind us that better conversations begin with better questions.</p>
          <p>He is not the voice of ConnectAloud.</p>
          <p>He is the companion who invites people into the conversation.</p>
        </div>
        <DinoCompanion class="why-dino-art" />
      </div>
    </Section>

    <Section id="about-m" title="About M">
      <div class="about-editorial-copy about-m-copy">
        <p class="editorial-emphasis">Hi, I’m M.</p>
        <p>I work in technology, but what interests me most is not technology by itself.</p>
        <p>I am interested in how people learn, think, communicate, lead, and make decisions alongside it.</p>
        <p>ConnectAloud is where I explore those questions out loud, document what I am learning, and invite others into the conversation.</p>
      </div>
    </Section>

    <Section id="the-conversation-continues" title="The Conversation Continues">
      <div class="closing-invitation">
        <div>
          <p>Whether you agree, disagree, or simply have another perspective, you are welcome here.</p>
          <p>The best conversations rarely end with certainty.</p>
          <p>They usually begin with a better question.</p>
        </div>
        <div class="about-actions">
          <Button href="/connectaloud">Start Reading</Button>
          <Button href="/connect" variant="secondary">Connect</Button>
        </div>
      </div>
    </Section>
  </div>
</BaseLayout>
