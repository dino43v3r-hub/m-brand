---
import Card from '../components/Card.astro';
import DinoCompanion from '../components/DinoCompanion.astro';
import Section from '../components/Section.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const pageDescription =
  'Explore current and future ConnectAloud projects where ideas become practical tools, research, or experiments.';
---

<BaseLayout title="Projects | ConnectAloud" description={pageDescription}>
  <section class="page-hero with-companion" aria-labelledby="page-title">
    <p class="eyebrow">Projects</p>
    <h1 id="page-title">Where ideas become practical tools, research, or experiments.</h1>
    <p class="lead">
      ConnectAloud projects are developing carefully. This page tracks work that is in progress, being explored, or still taking shape.
    </p>
    <DinoCompanion />
  </section>

  <Section id="current-projects" title="Current Projects">
    <div class="framework-panel">
      <p class="eyebrow">In progress</p>
      <h3>The first priority is building a thoughtful foundation for the publication itself.</h3>
      <p>
        Current work is focused on shaping ConnectAloud into a clear home for articles, resources, and future project notes. The goal is to build slowly enough that the structure can support meaningful work later.
      </p>
    </div>
  </Section>

  <Section id="research-projects" title="Research Projects">
    <p class="section-intro">
      Research projects are where questions can be explored with more patience, source awareness, and intellectual honesty.
    </p>
    <div class="focus-grid">
      <Card title="Responsible AI">
        <p>Exploring how AI systems can become more trustworthy, transparent, and useful while keeping human judgment visible.</p>
      </Card>
      <Card title="Knowledge work">
        <p>Developing ways to organize research, compare ideas, and make learning easier to revisit over time.</p>
      </Card>
      <Card title="Technology and theology">
        <p>Considering how technical change raises deeper questions about truth, responsibility, wisdom, and service.</p>
      </Card>
    </div>
  </Section>

  <Section id="experiments" title="Experiments">
    <div class="framework-panel">
      <p class="eyebrow">Testing with humility</p>
      <h3>Experiments are a way to learn before claiming too much.</h3>
      <p>
        Some ideas may become small tools, prompts, workflows, or examples. Others may simply clarify what is not useful yet. ConnectAloud treats both outcomes as part of learning.
      </p>
    </div>
  </Section>

  <Section id="future-work" title="Future Work">
    <div class="focus-grid">
      <Card title="Learning resources">
        <p>Developing resources that help readers approach complex topics with curiosity, care, and clearer questions.</p>
      </Card>
      <Card title="Practical tools">
        <p>Exploring simple tools that support reasoning, reflection, research, and responsible use of technology.</p>
      </Card>
      <Card title="Project notes">
        <p>Future updates may document what is being built, what is being learned, and what still needs more thought.</p>
      </Card>
    </div>
  </Section>
</BaseLayout>
